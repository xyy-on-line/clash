rules=RULE-SET,Local-LAN,DIRECT
rules=RULE-SET,SteamCN,DIRECT
rules=DOMAIN-SUFFIX,cm.steampowered.com,DIRECT
rules=DOMAIN-SUFFIX,steamserver.net,DIRECT
